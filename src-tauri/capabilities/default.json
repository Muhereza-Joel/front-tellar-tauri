{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "notification:default",
    "store:default",
    "store:allow-load",
    "core:window:allow-start-dragging",
    "updater:default",
    "process:allow-restart"
  ]
}
