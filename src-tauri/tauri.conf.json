{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrontTella",
  "version": "0.1.0",
  "identifier": "com.moelsgroup.front-tellar-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "FrontTella",
        "minWidth": 1200,
        "minHeight": 600,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "default": "sqlite:local.db",
      "preload": ["sqlite:local.db"]
    },
    "fs": {
      "scope": ["$APPDATA", "$RESOURCE", "$DESKTOP"]
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Muhereza-Joel/front-tellar-tauri/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCRTc0NTQ0RUI5MkNDOUUKUldTZXpKTHJSRVhuMjVsaHFia0FtTDcyQXdSemhlK3dxZmRaT2JGMEthdUo3L0dFdFBVNG1neisK"
    }
  }
}
